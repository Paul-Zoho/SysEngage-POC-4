modules = ["nodejs-24", "python-3.12", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[userenv]

[userenv.shared]
NEON_DATABASE_URL = "postgresql://neondb_owner:npg_YnR15KaHbvVZ@ep-muddy-mouse-abm8u7a1-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

[nix]
channel = "stable-25_05"
